<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="Lexora AI Keyboard"
        android:theme="@style/Theme.AIKeyboard">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".settings.LanguagesActivity"
            android:exported="false" />
        <activity
            android:name=".settings.PreferencesActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ThemeActivity"
            android:exported="false" />
        <activity
            android:name=".settings.CorrectionsActivity"
            android:exported="false" />
        <activity
            android:name=".settings.GlideTypingActivity"
            android:exported="false" />
        <activity
            android:name=".settings.VoiceTypingActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ClipboardActivity"
            android:exported="false" />
        <activity
            android:name=".settings.DictionaryActivity"
            android:exported="false" />
        <activity
            android:name=".settings.EmojisActivity"
            android:exported="false" />
        <activity
            android:name=".settings.PrivacyActivity"
            android:exported="false" />
        <activity
            android:name=".settings.RateUsActivity"
            android:exported="false" />
        <activity
            android:name=".settings.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".settings.HelpFeedbackActivity"
            android:exported="false" />

        <service
            android:name=".keyboard.AiKeyboardService"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>
</manifest>
