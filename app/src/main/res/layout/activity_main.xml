<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Headline -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/headline"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Keyboard Preview -->
        <ImageView
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/keyboard_mockup"
            android:layout_marginBottom="32dp" />

        <!-- Feature List -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Features"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/ai_reply"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/tone_changer"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/translate"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/grammar_check"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/summarize"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:text="@string/continue_writing"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp" />

        </LinearLayout>

        <!-- CTA Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_enable_keyboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enable_keyboard"
                android:backgroundTint="@color/button_primary"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_select_keyboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_keyboard"
                android:backgroundTint="@color/button_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/continue_btn"
                android:backgroundTint="@color/button_secondary"
                android:textColor="@color/text_primary"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>