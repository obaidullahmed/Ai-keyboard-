<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorKeyboardBackground"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/previewBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_surface_card"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/contextPreviewText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ready to type..."
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/languageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN"
            android:textColor="@color/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/previewActionButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/shape_keyboard_ai_key"
            android:text="AI"
            android:textColor="@color/colorTextPrimary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/aiToolsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/shape_surface_card"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <Button
                android:id="@+id/toolGrammar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_keyboard_key"
                android:text="✓"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:gravity="center" />

            <Button
                android:id="@+id/toolTone"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_keyboard_key"
                android:text="🎨"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:gravity="center" />

            <Button
                android:id="@+id/toolRewrite"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_keyboard_key"
                android:text="✍️"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:gravity="center" />

            <Button
                android:id="@+id/toolContinue"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_keyboard_key"
                android:text="→"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:gravity="center" />

            <Button
                android:id="@+id/toolTranslate"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/shape_keyboard_key"
                android:text="🌐"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:gravity="center" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/modeChipsScroll"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:scrollbars="none"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/modeChipsContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <Button
                    android:id="@+id/modeChip1"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minWidth="80dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/shape_suggestion_chip"
                    android:text="Casual"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/modeChip2"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minWidth="80dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/shape_suggestion_chip"
                    android:text="Professional"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/modeChip3"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minWidth="80dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/shape_suggestion_chip"
                    android:text="Friendly"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/resultsCardsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/shape_surface_card"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/resultsLoadingProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/resultsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Generating..."
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <Button
            android:id="@+id/resultCard1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shape_surface_card"
            android:text="Result 1"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <Button
            android:id="@+id/resultCard2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shape_surface_card"
            android:text="Result 2"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
<Button
            android:id="@+id/resultCard3"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shape_surface_card"
            android:text="Result 3"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/suggestionBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_surface_card"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/suggestionChip1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Suggestion 1"
            android:textColor="@color/colorTextPrimary"
            android:background="@drawable/shape_suggestion_chip"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/suggestionChip2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Suggestion 2"
            android:textColor="@color/colorTextPrimary"
            android:background="@drawable/shape_suggestion_chip"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/suggestionChip3"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Suggestion 3"
            android:textColor="@color/colorTextPrimary"
            android:background="@drawable/shape_suggestion_chip"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/keyboardKeysContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/numberRow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:visibility="gone">

                <Button android:id="@+id/key1" style="@style/KeyboardKeyStyle" android:text="1" />
                <Button android:id="@+id/key2" style="@style/KeyboardKeyStyle" android:text="2" />
                <Button android:id="@+id/key3" style="@style/KeyboardKeyStyle" android:text="3" />
                <Button android:id="@+id/key4" style="@style/KeyboardKeyStyle" android:text="4" />
                <Button android:id="@+id/key5" style="@style/KeyboardKeyStyle" android:text="5" />
                <Button android:id="@+id/key6" style="@style/KeyboardKeyStyle" android:text="6" />
                <Button android:id="@+id/key7" style="@style/KeyboardKeyStyle" android:text="7" />
                <Button android:id="@+id/key8" style="@style/KeyboardKeyStyle" android:text="8" />
                <Button android:id="@+id/key9" style="@style/KeyboardKeyStyle" android:text="9" />
                <Button android:id="@+id/key0" style="@style/KeyboardKeyStyle" android:text="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp">

                <Button android:id="@+id/keyQ" style="@style/KeyboardKeyStyle" android:text="Q" />
                <Button android:id="@+id/keyW" style="@style/KeyboardKeyStyle" android:text="W" />
                <Button android:id="@+id/keyE" style="@style/KeyboardKeyStyle" android:text="E" />
                <Button android:id="@+id/keyR" style="@style/KeyboardKeyStyle" android:text="R" />
                <Button android:id="@+id/keyT" style="@style/KeyboardKeyStyle" android:text="T" />
                <Button android:id="@+id/keyY" style="@style/KeyboardKeyStyle" android:text="Y" />
                <Button android:id="@+id/keyU" style="@style/KeyboardKeyStyle" android:text="U" />
                <Button android:id="@+id/keyI" style="@style/KeyboardKeyStyle" android:text="I" />
                <Button android:id="@+id/keyO" style="@style/KeyboardKeyStyle" android:text="O" />
                <Button android:id="@+id/keyP" style="@style/KeyboardKeyStyle" android:text="P" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp">

                <Button android:id="@+id/keyA" style="@style/KeyboardKeyStyle" android:text="A" />
                <Button android:id="@+id/keyS" style="@style/KeyboardKeyStyle" android:text="S" />
                <Button android:id="@+id/keyD" style="@style/KeyboardKeyStyle" android:text="D" />
                <Button android:id="@+id/keyF" style="@style/KeyboardKeyStyle" android:text="F" />
                <Button android:id="@+id/keyG" style="@style/KeyboardKeyStyle" android:text="G" />
                <Button android:id="@+id/keyH" style="@style/KeyboardKeyStyle" android:text="H" />
                <Button android:id="@+id/keyJ" style="@style/KeyboardKeyStyle" android:text="J" />
                <Button android:id="@+id/keyK" style="@style/KeyboardKeyStyle" android:text="K" />
                <Button android:id="@+id/keyL" style="@style/KeyboardKeyStyle" android:text="L" />
                <Button android:id="@+id/keyBackspace" style="@style/KeyboardActionKeyStyle" android:text="⌫" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/keyShift"
                    style="@style/KeyboardActionKeyStyle"
                    android:layout_marginEnd="4dp"
                    android:text="⇧" />

                <Button android:id="@+id/keyZ" style="@style/KeyboardKeyStyle" android:text="Z" />
                <Button android:id="@+id/keyX" style="@style/KeyboardKeyStyle" android:text="X" />
                <Button android:id="@+id/keyC" style="@style/KeyboardKeyStyle" android:text="C" />
                <Button android:id="@+id/keyV" style="@style/KeyboardKeyStyle" android:text="V" />
                <Button android:id="@+id/keyB" style="@style/KeyboardKeyStyle" android:text="B" />
                <Button android:id="@+id/keyN" style="@style/KeyboardKeyStyle" android:text="N" />
                <Button android:id="@+id/keyM" style="@style/KeyboardKeyStyle" android:text="M" />

                <Button
                    android:id="@+id/keyEnter"
                    style="@style/KeyboardActionKeyStyle"
                    android:layout_marginStart="4dp"
                    android:text="↵" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <Button
                    android:id="@+id/keySwitchMode"
                    style="@style/KeyboardActionKeyStyle"
                    android:layout_marginEnd="4dp"
                    android:text="?123" />

                <Button
                    android:id="@+id/keyEmoji"
                    style="@style/KeyboardActionKeyStyle"
                    android:layout_marginEnd="4dp"
                    android:text="😊" />

                <Button
                    android:id="@+id/keySpace"
                    style="@style/KeyboardKeyStyle"
                    android:layout_weight="3"
                    android:layout_marginEnd="4dp"
                    android:text="Space" />
<Button
                    android:id="@+id/keyAiAction"
                    style="@style/KeyboardAiKeyStyle"
                    android:text="AI" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/emojiPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/shape_surface_card"
            android:visibility="gone"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/emojiHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Emoji keyboard"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <Button
                    android:id="@+id/emojiButton1"
                    style="@style/KeyboardKeyStyle"
                    android:text="😀" />
                <Button
                    android:id="@+id/emojiButton2"
                    style="@style/KeyboardKeyStyle"
                    android:text="😂" />
                <Button
                    android:id="@+id/emojiButton3"
                    style="@style/KeyboardKeyStyle"
                    android:text="😍" />
                <Button
                    android:id="@+id/emojiButton4"
                    style="@style/KeyboardKeyStyle"
                    android:text="👍" />
                <Button
                    android:id="@+id/emojiButton5"
                    style="@style/KeyboardKeyStyle"
                    android:text="🙏" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/emojiButton6"
                    style="@style/KeyboardKeyStyle"
                    android:text="🥳" />
                <Button
                    android:id="@+id/emojiButton7"
                    style="@style/KeyboardKeyStyle"
                    android:text="❤️" />
                <Button
                    android:id="@+id/emojiButton8"
                    style="@style/KeyboardKeyStyle"
                    android:text="🚀" />
                <Button
                    android:id="@+id/emojiButton9"
                    style="@style/KeyboardKeyStyle"
                    android:text="✨" />
                <Button
                    android:id="@+id/emojiButton10"
                    style="@style/KeyboardKeyStyle"
                    android:text="🔥" />
            </LinearLayout>

            <Button
                android:id="@+id/panelCloseKeyboard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/shape_keyboard_action_key"
                android:text="Keyboard"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
                
        
