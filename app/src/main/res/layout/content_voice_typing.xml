<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable voice typing to use the Android speech recognition flow from the keyboard. Tap the button below to test the system integration."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <Switch
        android:id="@+id/switchVoiceTyping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/voice_enabled"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/buttonStartVoiceTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/voice_test_button"
        android:backgroundTint="@color/button_primary"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/voiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />
</LinearLayout>
