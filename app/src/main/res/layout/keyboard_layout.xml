<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@color/keyboardBackground">

    <LinearLayout
        android:id="@+id/suggestionStrip"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#1A1E25">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/suggestionChip1"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:background="@drawable/suggestion_chip_background"
                    android:text="Tap AI for reply"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />

                <TextView
                    android:id="@+id/suggestionChip2"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:background="@drawable/suggestion_chip_background"
                    android:text="Need context"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />

                <TextView
                    android:id="@+id/suggestionChip3"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="@drawable/suggestion_chip_background"
                    android:text="Manual trigger only"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <ProgressBar
            android:id="@+id/loadingIndicator"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:indeterminateTint="#FFFFFF" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keyboardKeys"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="10"
        android:rowCount="5"
        android:paddingTop="8dp">

        <!-- Number row -->
        <Button
            android:id="@+id/key1"
            style="@style/KeyboardKeyStyle"
            android:text="1" />
        <Button
            android:id="@+id/key2"
            style="@style/KeyboardKeyStyle"
            android:text="2" />
        <Button
            android:id="@+id/key3"
            style="@style/KeyboardKeyStyle"
            android:text="3" />
        <Button
            android:id="@+id/key4"
            style="@style/KeyboardKeyStyle"
            android:text="4" />
        <Button
            android:id="@+id/key5"
            style="@style/KeyboardKeyStyle"
            android:text="5" />
        <Button
            android:id="@+id/key6"
            style="@style/KeyboardKeyStyle"
            android:text="6" />
        <Button
            android:id="@+id/key7"
            style="@style/KeyboardKeyStyle"
            android:text="7" />
        <Button
            android:id="@+id/key8"
            style="@style/KeyboardKeyStyle"
            android:text="8" />
        <Button
            android:id="@+id/key9"
            style="@style/KeyboardKeyStyle"
            android:text="9" />
        <Button
            android:id="@+id/key0"
            style="@style/KeyboardKeyStyle"
            android:text="0" />
            android:id="@+id/keyX"
            style="@style/KeyboardKeyStyle"
            android:text="X" />
        <Button
            android:id="@+id/keyC"
            style="@style/KeyboardKeyStyle"
            android:text="C" />
        <Button
            android:id="@+id/keyV"
            style="@style/KeyboardKeyStyle"
            android:text="V" />
        <Button
            android:id="@+id/keyB"
            style="@style/KeyboardKeyStyle"
            android:text="B" />
        <Button
            android:id="@+id/keyN"
            style="@style/KeyboardKeyStyle"
            android:text="N" />
        <Button
            android:id="@+id/keyM"
            style="@style/KeyboardKeyStyle"
            android:text="M" />
        <Button
            android:id="@+id/keySpace"
            style="@style/KeyboardActionKeyStyle"
            android:text="Space"
            android:layout_columnSpan="3" />
        <Button
            android:id="@+id/keyEnter"
            style="@style/KeyboardActionKeyStyle"
            android:text="Enter" />

        <!-- Row 4 -->
        <Button
            android:id="@+id/keyAiAction"
            style="@style/KeyboardAiKeyStyle"
            android:text="AI" 
            android:layout_columnSpan="10" />
    </GridLayout>
</LinearLayout>
