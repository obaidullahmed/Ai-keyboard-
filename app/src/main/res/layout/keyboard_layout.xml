<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#070F1E"
    android:padding="6dp">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:text="Tap AI for reply"
            android:textColor="#AFCBFF"
            android:background="@drawable/shape_suggestion_chip"
            android:padding="10dp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:text="Need context"
            android:textColor="#AFCBFF"
            android:background="@drawable/shape_suggestion_chip"
            android:padding="10dp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:text="Manual trigger"
            android:textColor="#AFCBFF"
            android:background="@drawable/shape_suggestion_chip"
            android:padding="10dp"/>
    </LinearLayout>

    <!-- ROW 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <Button style="@style/KeyboardKeyStyle" android:text="Q"/>
        <Button style="@style/KeyboardKeyStyle" android:text="W"/>
        <Button style="@style/KeyboardKeyStyle" android:text="E"/>
        <Button style="@style/KeyboardKeyStyle" android:text="R"/>
        <Button style="@style/KeyboardKeyStyle" android:text="T"/>
        <Button style="@style/KeyboardKeyStyle" android:text="Y"/>
        <Button style="@style/KeyboardKeyStyle" android:text="U"/>
        <Button style="@style/KeyboardKeyStyle" android:text="I"/>
        <Button style="@style/KeyboardKeyStyle" android:text="O"/>
        <Button style="@style/KeyboardKeyStyle" android:text="P"/>
    </LinearLayout>

    <!-- ROW 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <Button style="@style/KeyboardKeyStyle" android:text="A"/>
        <Button style="@style/KeyboardKeyStyle" android:text="S"/>
        <Button style="@style/KeyboardKeyStyle" android:text="D"/>
        <Button style="@style/KeyboardKeyStyle" android:text="F"/>
        <Button style="@style/KeyboardKeyStyle" android:text="G"/>
        <Button style="@style/KeyboardKeyStyle" android:text="H"/>
        <Button style="@style/KeyboardKeyStyle" android:text="J"/>
        <Button style="@style/KeyboardKeyStyle" android:text="K"/>
        <Button style="@style/KeyboardKeyStyle" android:text="L"/>

        <Button
            style="@style/KeyboardActionKeyStyle"
            android:text="⌫"/>
    </LinearLayout>

    <!-- ROW 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <Button style="@style/KeyboardActionKeyStyle" android:text="⇧"/>

        <Button style="@style/KeyboardKeyStyle" android:text="Z"/>
        <Button style="@style/KeyboardKeyStyle" android:text="X"/>
        <Button style="@style/KeyboardKeyStyle" android:text="C"/>
        <Button style="@style/KeyboardKeyStyle" android:text="V"/>
        <Button style="@style/KeyboardKeyStyle" android:text="B"/>
        <Button style="@style/KeyboardKeyStyle" android:text="N"/>
        <Button style="@style/KeyboardKeyStyle" android:text="M"/>

        <Button style="@style/KeyboardActionKeyStyle" android:text="↵"/>
    </LinearLayout>

    <!-- ROW 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp">

        <Button style="@style/KeyboardActionKeyStyle" android:text="?123"/>
        <Button style="@style/KeyboardActionKeyStyle" android:text="😊"/>

        <Button
            style="@style/KeyboardKeyStyle"
            android:layout_weight="3"
            android:text="Space"/>

        <Button
            style="@style/KeyboardAiKeyStyle"
            android:text="AI"/>
    </LinearLayout>

</LinearLayout>
